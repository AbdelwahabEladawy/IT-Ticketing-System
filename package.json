{
    "name": "it-ticketing-system",
    "version": "1.0.0",
    "description": "Full-stack IT Ticketing System",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "cd server && npm run dev",
        "dev:client": "cd client && npm run dev",
        "build": "cd client && npm run build",
        "start": "cd server && npm start",
        "prisma:generate": "cd server && npx prisma generate",
        "prisma:migrate": "cd server && npx prisma migrate dev",
        "prisma:studio": "cd server && npx prisma studio"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "packageManager": "yarn@4.2.2+sha512.c44e283c54e02de9d1da8687025b030078c1b9648d2895a65aab8e64225bfb7becba87e1809fc0b4b6778bbd47a1e2ab6ac647de4c5e383a53a7c17db6c3ff4b"
}
