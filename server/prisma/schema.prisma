// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("SERVER_DATABASE_URL")
}

enum UserRole {
    USER
    TECHNICIAN
    IT_ADMIN
    IT_MANAGER
    SUPER_ADMIN
    SOFTWARE_ENGINEER
    BASIC_USER
} 

enum TicketStatus {
    OPEN
    ASSIGNED
    IN_PROGRESS
    RESOLVED
    CLOSED
    USER_ACTION_NEEDED
}

enum TechnicianStatus {
    AVAILABLE
    BUSY
    OFFLINE
}

enum AccountStatus {
    ACTIVE
    ON_HOLD
}

enum TicketMessageType {
    ACTION_REQUEST
    USER_REPLY
    /// User follow-up after resolution (same thread as other ticket messages)
    RESOLVED_COMMENT
}

enum TicketReassignmentRequestStatus {
    PENDING
    APPROVED
    REJECTED
    AUTO_APPROVED
}

enum SuggestionStatus {
    UNSEEN
    SEEN
}

enum ProblemType {
    PREDEFINED
    CUSTOM
}

enum ScheduledTaskType {
    ONE_TIME
    YEARLY
}

enum ScheduledTaskRunStatus {
    SUCCESS
    FAILED
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    password  String
    name      String
    role      UserRole @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // If true, the user must change the password on first login (e.g., bulk imports)
    mustChangePassword Boolean @default(false)

    /// UI language: "en" | "ar" (notifications + client sync)
    preferredLocale String @default("en")
    accountStatus AccountStatus @default(ACTIVE)
    deletedAt DateTime?

    // Technician specific fields
    specializationId String?
    specialization   Specialization?   @relation(fields: [specializationId], references: [id])
    status           TechnicianStatus? @default(AVAILABLE)
    isOnline         Boolean           @default(false)
    lastSeenAt       DateTime?
    presenceUpdatedAt DateTime?
    presenceSessionId String?

    // Relations
    createdTickets  Ticket[]   @relation("CreatedBy")
    assignedTickets Ticket[]   @relation("AssignedTo")
    ticketMessagesAuthored TicketMessage[] @relation("TicketMessageAuthor")
    ticketMessagesReceived TicketMessage[] @relation("TicketMessageRecipient")
    reassignmentRequestsCreated TicketReassignmentRequest[] @relation("TicketReassignmentRequestedBy")
    reassignmentRequestsFrom TicketReassignmentRequest[] @relation("TicketReassignmentFromEngineer")
    reassignmentRequestsTo TicketReassignmentRequest[] @relation("TicketReassignmentToEngineer")
    reassignmentRequestsDecided TicketReassignmentRequest[] @relation("TicketReassignmentDecidedBy")
    auditLogs       AuditLog[]
    achievements   Achievement[]
    suggestions     Suggestion[]
    notifications   Notification[]
    scheduledTasksCreated ScheduledTicketTask[] @relation("ScheduledTaskCreator")
    scheduledTasksAssigned ScheduledTicketTask[] @relation("ScheduledTaskTarget")

    @@index([email])
    @@index([role])
    @@index([specializationId])
    @@index([specializationId, isOnline])
    @@index([lastSeenAt])
}

model Specialization {
    id          String   @id @default(cuid())
    name        String   @unique
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    technicians User[]
    tickets     Ticket[]

    @@index([name])
}

model Ticket {
    id            String       @id @default(cuid())
    title         String
    description   String
    problemType   ProblemType  @default(PREDEFINED)
    issueType     String? // Optional: Predefined issue type for direct team routing
    status        TicketStatus @default(OPEN)
    anydeskNumber String? // Anydesk number for remote access
    deviceIp      String? // Captured automatically from the request when available

    // SLA tracking
    slaHours    Int       @default(24) // Default 24 hours SLA
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    assignedAt  DateTime?
    resolvedAt  DateTime?
    closedAt    DateTime?
    slaDeadline DateTime?

    // Relations
    createdById String
    createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

    assignedToId String?
    assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

    specializationId String?
    specialization   Specialization? @relation(fields: [specializationId], references: [id])

    auditLogs AuditLog[]
    messages  TicketMessage[]
    reassignmentRequests TicketReassignmentRequest[]
    scheduledTaskRuns ScheduledTaskRun[]

    @@index([createdById])
    @@index([assignedToId])
    @@index([status])
    @@index([specializationId])
    @@index([problemType])
}

model TicketReassignmentRequest {
    id            String                          @id @default(cuid())
    ticketId      String
    ticket        Ticket                          @relation(fields: [ticketId], references: [id], onDelete: Cascade)

    requestedById String
    requestedBy   User                            @relation("TicketReassignmentRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)

    fromEngineerId String?
    fromEngineer   User?                          @relation("TicketReassignmentFromEngineer", fields: [fromEngineerId], references: [id], onDelete: SetNull)

    toEngineerId  String
    toEngineer    User                            @relation("TicketReassignmentToEngineer", fields: [toEngineerId], references: [id], onDelete: Cascade)

    status        TicketReassignmentRequestStatus @default(PENDING)
    reason        String?
    rejectionReason String?

    autoApproveAt DateTime
    decidedAt     DateTime?
    autoApprovedAt DateTime?
    processedAt   DateTime?

    decidedById   String?
    decidedBy     User?                           @relation("TicketReassignmentDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

    createdAt     DateTime                        @default(now())
    updatedAt     DateTime                        @default(now()) @updatedAt

    @@index([ticketId, createdAt])
    @@index([requestedById, createdAt])
    @@index([status, autoApproveAt])
    @@index([toEngineerId, createdAt])
}

model AuditLog {
    id          String   @id @default(cuid())
    action      String // e.g., "TICKET_CREATED", "TICKET_ASSIGNED", "STATUS_CHANGED"
    description String
    metadata    String? // JSON string for additional data
    createdAt   DateTime @default(now())

    // Relations
    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    ticketId String?
    ticket   Ticket? @relation(fields: [ticketId], references: [id])

    @@index([userId])
    @@index([ticketId])
    @@index([createdAt])
    @@index([action])
}

model Notification {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title     String
    message   String
    type      String   @default("info") // info, warning, success, error
    read      Boolean  @default(false)
    createdAt DateTime @default(now())

    ticketId String?
    suggestionId String?
    suggestion   Suggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([read])
    @@index([createdAt])
    @@index([suggestionId])
}

model Suggestion {
    id          String           @id @default(cuid())
    title       String
    description String
    status      SuggestionStatus @default(UNSEEN)
    createdById String
    createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt

    notifications Notification[]

    @@index([createdById])
    @@index([status])
    @@index([createdAt])
}

model Achievement {
    id          String   @id @default(cuid())
    title       String
    description String
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
    @@index([userId, createdAt])
}

model TicketMessage {
    id        String             @id @default(cuid())
    ticketId  String
    ticket    Ticket             @relation(fields: [ticketId], references: [id])

    // Message author (engineer or user)
    authorId String
    author   User               @relation("TicketMessageAuthor", fields: [authorId], references: [id])

    // Recipient for realtime delivery and UI filtering
    toUserId String
    toUser   User               @relation("TicketMessageRecipient", fields: [toUserId], references: [id])

    // Threading: action request has parentId = null; replies reference the request id
    parentId String?
    parent   TicketMessage?    @relation("TicketMessageThread", fields: [parentId], references: [id])
    children TicketMessage[]   @relation("TicketMessageThread")

    type      TicketMessageType
    body      String
    createdAt DateTime           @default(now())

    @@index([ticketId, createdAt])
    @@index([toUserId, createdAt])
    @@index([authorId])
    @@index([parentId])
    @@index([type])
}

model ScheduledTicketTask {
    id          String            @id @default(cuid())
    title       String
    description String?
    scheduleType ScheduledTaskType
    runDate     String? // YYYY-MM-DD for ONE_TIME
    month       Int?
    day         Int?
    timeOfDay   String            @default("09:00") // HH:mm
    timezone    String            @default("Africa/Cairo")
    nextRunAt   DateTime
    isActive    Boolean           @default(true)

    targetUserId String
    targetUser   User             @relation("ScheduledTaskTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

    createdById String
    createdBy   User              @relation("ScheduledTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

    createdAt   DateTime          @default(now())
    updatedAt   DateTime          @updatedAt

    runs ScheduledTaskRun[]

    @@index([isActive, nextRunAt])
    @@index([targetUserId, isActive])
    @@index([createdById])
}

model ScheduledTaskRun {
    id        String                 @id @default(cuid())
    scheduledTaskId String
    scheduledTask   ScheduledTicketTask @relation(fields: [scheduledTaskId], references: [id], onDelete: Cascade)
    scheduledFor DateTime
    status    ScheduledTaskRunStatus
    trigger   String                 @default("AUTO") // AUTO | MANUAL
    ticketId  String?
    ticket    Ticket?                @relation(fields: [ticketId], references: [id], onDelete: SetNull)
    errorMessage String?
    executedAt DateTime              @default(now())

    @@unique([scheduledTaskId, scheduledFor])
    @@index([scheduledTaskId, executedAt])
    @@index([status])
}

model RebalanceJob {
    id            String   @id @default(cuid())
    specializationId String
    trigger       String
    status        String   @default("PENDING")
    createdAt     DateTime @default(now())
    processedAt   DateTime?

    @@index([specializationId, status])
    @@index([createdAt])
}
